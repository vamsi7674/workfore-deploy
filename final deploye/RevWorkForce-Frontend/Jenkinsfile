pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '5'))
        timestamps()
    }

    environment {
        // ----- UPDATE THESE -----
        S3_BUCKET     = 'your-hrms-frontend-bucket'   // UPDATE: your S3 bucket name
        AWS_REGION    = 'ap-south-1'                   // UPDATE: your AWS region
        // ----- Jenkins Credential IDs -----
        AWS_CREDS_ID  = 'aws-s3-credentials'           // Jenkins: AWS Access Key + Secret
    }

    stages {

        stage('Checkout') {
            steps {
                echo '--- Checking out frontend code from GitHub ---'
                git branch: 'main',
                    credentialsId: 'github-ssh-key',
                    url: 'git@github.com:vamsi7674/workfore-deploy.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo '--- Installing npm packages ---'
                dir('final deploye/RevWorkForce-Frontend') {
                    sh '''
                        node --version
                        npm --version
                        npm ci --prefer-offline
                    '''
                }
            }
        }

        stage('Build Angular App') {
            steps {
                echo '--- Building Angular app for production ---'
                dir('final deploye/RevWorkForce-Frontend') {
                    sh 'npx ng build --configuration production'
                }
            }
        }

        stage('Deploy to S3') {
            steps {
                echo '--- Syncing dist/ to AWS S3 ---'
                withCredentials([usernamePassword(
                    credentialsId: "${AWS_CREDS_ID}",
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    dir('final deploye/RevWorkForce-Frontend') {
                        sh """
                            aws s3 sync dist/HRMS-Portal/browser/ s3://${S3_BUCKET}/ \
                                --region ${AWS_REGION} \
                                --delete \
                                --cache-control 'public, max-age=31536000' \
                                --exclude 'index.html'

                            # index.html must NOT be cached so routing works
                            aws s3 cp dist/HRMS-Portal/browser/index.html s3://${S3_BUCKET}/index.html \
                                --region ${AWS_REGION} \
                                --cache-control 'no-cache, no-store, must-revalidate' \
                                --content-type 'text/html'

                            echo "✅ Frontend deployed to: http://${S3_BUCKET}.s3-website-${AWS_REGION}.amazonaws.com"
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo '✅ Frontend deployment SUCCESS — Angular app is live on S3'
        }
        failure {
            echo '❌ Frontend deployment FAILED — check logs above'
        }
    }
}
