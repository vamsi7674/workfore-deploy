# ============================================================
# HRMS Workforce Backend - Environment Variables Template
# ============================================================
# Copy this file to .env on the EC2 server and fill in values.
# DO NOT commit the .env file to Git — add it to .gitignore.
# Jenkins injects these automatically via deploy.sh.
# ============================================================

# ----- MySQL Database -----
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=workforce_db
MYSQL_USER=workforce_user
MYSQL_PASSWORD=your_db_password_here

# ----- Spring Boot -----
SPRING_PROFILES_ACTIVE=prod
APP_PORT=8080

# ----- Mail (for OTP / notifications) -----
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password_here
