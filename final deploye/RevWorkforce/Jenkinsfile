pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'Maven3'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '5'))
        timestamps()
    }

    environment {
        // --- App Config ---
        JAR_NAME        = 'Workforce-0.0.1-SNAPSHOT.jar'
        APP_PORT        = '8080'
        // --- EC2 Remote Config ---
        REMOTE_USER     = 'ec2-user'
        REMOTE_HOST     = '13.200.249.90'         // UPDATE: your new EC2 Elastic IP
        REMOTE_DIR      = '/home/ec2-user/workforce'
        // --- Jenkins Credentials IDs (configure these in Jenkins) ---
        EC2_SSH_KEY_ID  = 'ec2-ssh-key'           // Jenkins credential: SSH private key for EC2
    }

    stages {

        stage('Checkout') {
            steps {
                echo '--- Checking out code from GitHub ---'
                git branch: 'main',
                    credentialsId: 'github-ssh-key',
                    url: 'git@github.com:vamsi7674/workfore-deploy.git'
            }
        }

        stage('Build JAR') {
            steps {
                echo '--- Building Spring Boot JAR ---'
                dir('final deploye/RevWorkforce') {
                    sh 'mvn -B clean package -DskipTests -q'
                    archiveArtifacts artifacts: "target/${JAR_NAME}", fingerprint: true
                }
            }
        }

        stage('Transfer Files to EC2') {
            steps {
                echo '--- Transferring JAR and compose files to EC2 ---'
                withCredentials([sshUserPrivateKey(
                    credentialsId: "${EC2_SSH_KEY_ID}",
                    keyFileVariable: 'SSH_KEY'
                )]) {
                    sh """
                        # Ensure remote directory exists
                        ssh -o StrictHostKeyChecking=no -i \$SSH_KEY ${REMOTE_USER}@${REMOTE_HOST} \
                            'mkdir -p ${REMOTE_DIR}'

                        # Transfer JAR
                        scp -o StrictHostKeyChecking=no -i \$SSH_KEY \
                            'final deploye/RevWorkforce/target/${JAR_NAME}' \
                            ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_DIR}/

                        # Transfer docker-compose and deploy script
                        scp -o StrictHostKeyChecking=no -i \$SSH_KEY \
                            'final deploye/RevWorkforce/docker-compose.yml' \
                            ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_DIR}/

                        scp -o StrictHostKeyChecking=no -i \$SSH_KEY \
                            'final deploye/RevWorkforce/deploy.sh' \
                            ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_DIR}/
                    """
                }
            }
        }

        stage('Deploy on EC2') {
            steps {
                echo '--- Deploying containers on EC2 via Docker Compose ---'
                withCredentials([
                    sshUserPrivateKey(
                        credentialsId: "${EC2_SSH_KEY_ID}",
                        keyFileVariable: 'SSH_KEY'
                    ),
                    string(credentialsId: 'mysql-root-password',  secretVariable: 'MYSQL_ROOT_PASS'),
                    string(credentialsId: 'mysql-user-password',  secretVariable: 'MYSQL_USER_PASS'),
                    string(credentialsId: 'spring-mail-password', secretVariable: 'MAIL_PASS')
                ]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no -i \$SSH_KEY ${REMOTE_USER}@${REMOTE_HOST} \
                        "MYSQL_ROOT_PASSWORD='\$MYSQL_ROOT_PASS' \
                         MYSQL_PASSWORD='\$MYSQL_USER_PASS' \
                         SPRING_MAIL_PASSWORD='\$MAIL_PASS' \
                         JAR_NAME='${JAR_NAME}' \
                         APP_PORT='${APP_PORT}' \
                         bash ${REMOTE_DIR}/deploy.sh"
                    """
                }
            }
        }
    }

    post {
        success {
            echo '✅ Backend deployment SUCCESS — containers are up on EC2'
        }
        failure {
            echo '❌ Deployment FAILED — check the logs above for errors'
        }
        unstable {
            echo '⚠️ Build UNSTABLE — review test results'
        }
    }
}
